#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

os="$(uname -s)"
arch="$(uname -m)"

case "$os" in
  Darwin)
    platform="darwin"
    ;;
  Linux)
    platform="linux"
    ;;
  *)
    echo "Unsupported operating system: $os" >&2
    exit 1
    ;;
esac

if [ "$platform" = "darwin" ]; then
  target_arch="amd64"
else
  case "$arch" in
    x86_64|amd64)
      target_arch="amd64"
      ;;
    arm64|aarch64)
      target_arch="arm64"
      ;;
    *)
      echo "Unsupported architecture: $arch" >&2
      exit 1
      ;;
  esac
fi

binary_name="viking-cli-${platform}-${target_arch}"

binary_path="$SCRIPT_DIR/$binary_name"

if [ ! -f "$binary_path" ]; then
  echo "No bundled binary found for ${platform}/${target_arch}: $binary_name" >&2
  echo "Available binaries:" >&2
  ls -1 "$SCRIPT_DIR"/viking-cli-* 2>/dev/null >&2 || true
  exit 1
fi

exec "$binary_path" "$@"
